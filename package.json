{
    "name": "filepond-extension-pintura-transform",
    "description": "Pintura extension for FilePond.",
    "version": "0.0.4",
    "author": "Rik Schennink",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@pqina/pintura": "^8.x",
        "filepond": "^5.0.0-beta.41"
    },
    "devDependencies": {
        "tsdown": "^0.21.10",
        "typescript": "^6.0.3"
    }
}
